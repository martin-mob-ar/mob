# ============================================================================
# .env.local.example — Local development environment template
# ============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Variables marked [per-env] have different values per environment
# (production / preview / local). Variables marked [shared] are the
# same across all environments.
# ============================================================================


# ----------------------------------------------------------------------------
# Supabase [per-env] — Use branch credentials for local dev
# ----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/<branch-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<branch-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-branch-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-branch-service-role-key"

# ----------------------------------------------------------------------------
# App URL [per-env]
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Tokko API [shared]
# ----------------------------------------------------------------------------
TOKKO_BASE_URL="https://www.tokkobroker.com/api/v1"

# ----------------------------------------------------------------------------
# Google OAuth & Maps [shared]
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ----------------------------------------------------------------------------
# GCS — Property photo storage [shared]
# ----------------------------------------------------------------------------
GCS_BUCKET_NAME="mob-property-photos"
GCS_CLIENT_EMAIL="your-gcs-service-account@project.iam.gserviceaccount.com"
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCS_PROJECT_ID="your-gcs-project-id"

# ----------------------------------------------------------------------------
# Truora — Identity verification [per-env: flow IDs differ]
# ----------------------------------------------------------------------------
TRUORA_API_KEY="your-truora-api-key"
TRUORA_FLOW_ID="your-truora-flow-id"
TRUORA_FLOW_ID_NO_PROPERTY="your-truora-flow-id-no-property"
TRUORA_OUTBOUND_ID="your-truora-outbound-id"
TRUORA_OUTBOUND_ID_NO_PROPERTY="your-truora-outbound-id-no-property"
TRUORA_OUTBOUND_ID_CERTIFICADO="your-truora-outbound-id-certificado"
TRUORA_WEBHOOK_SECRET="your-truora-webhook-secret"

# ----------------------------------------------------------------------------
# Hoggax — Financial verification API [shared]
# ----------------------------------------------------------------------------
HOGGAX_API_URL="https://8zml5tuq2b.execute-api.us-east-2.amazonaws.com/dev"

# ----------------------------------------------------------------------------
# Kapso — WhatsApp integration [shared]
# ----------------------------------------------------------------------------
# KAPSO_API_KEY="your-kapso-api-key"
# KAPSO_API_BASE_URL="https://api.kapso.ai"
# KAPSO_PHONE_NUMBER_ID="your-kapso-phone-number-id"
# KAPSO_WEBHOOK_SECRET="your-kapso-webhook-secret"
# META_GRAPH_VERSION="v21.0"
# ALERT_WHATSAPP_PHONE="5492236000055"  # Internal alerts recipient

# ----------------------------------------------------------------------------
# Email — Resend [shared]
# ----------------------------------------------------------------------------
RESEND_API_KEY="your-resend-api-key"
LEAD_FROM_EMAIL="no-reply@leads.mob.ar"
LEAD_CC_EMAIL="your-cc-email@mob.ar"
MAILING_UNSUBSCRIBE_SECRET="your-mailing-unsubscribe-secret"

# ----------------------------------------------------------------------------
# Notion — Lead tracking [shared]
# ----------------------------------------------------------------------------
NOTION_API_KEY="your-notion-api-key"
NOTION_LEADS_DATABASE_ID="your-notion-database-id"

# ----------------------------------------------------------------------------
# Sanity CMS [shared]
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID="your-sanity-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_REVALIDATE_SECRET="your-sanity-revalidate-secret"

# ----------------------------------------------------------------------------
# Sentry — Error tracking [shared]
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# ----------------------------------------------------------------------------
# AI Gateway [shared]
# ----------------------------------------------------------------------------
AI_GATEWAY_API_KEY="your-ai-gateway-api-key"

# ----------------------------------------------------------------------------
# Encryption [shared]
# ----------------------------------------------------------------------------
API_KEY_SECRET="your-api-key-secret"

# ----------------------------------------------------------------------------
# Analytics — Microsoft Clarity [shared]
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CLARITY_ID="your-clarity-id"

# ----------------------------------------------------------------------------
# GTM — Production only (omit for local/preview)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# ----------------------------------------------------------------------------
# Cron — Production only (omit to disable cron jobs locally)
# ----------------------------------------------------------------------------
# CRON_SECRET="your-cron-secret"
